<!-- ============================================
     DOODLETYPE — CHARACTERS PAGE
     ============================================ -->

<!-- PAGE HERO -->
<section class="chars-hero">
  <div class="chars-hero__inner">
    <p class="chars-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="chars-hero__headline">
      {{ section.settings.headline | replace: 'Characters', '<span class="chars-hero__headline-red">Characters</span>' }}
    </h1>
    <p class="chars-hero__subtext">{{ section.settings.subtext }}</p>
  </div>

  <!-- Marquee -->
  <div class="chars-marquee">
    <div class="chars-marquee__track">
      <div class="chars-marquee__content">
        <span>{{ section.settings.marquee_text }}</span>
        <span>{{ section.settings.marquee_text }}</span>
      </div>
    </div>
  </div>
</section>

