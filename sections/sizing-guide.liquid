<section class="sizing-hero">
  <div class="container">
    <p class="sizing-hero__eyebrow">FIT GUIDE</p>
    <h1 class="sizing-hero__heading">Find Your Size</h1>
    <p class="sizing-hero__sub">All tees are unisex. When in doubt, size up — they look great oversized.</p>
  </div>
</section>

<section class="sizing-table-section">
  <div class="container container--narrow">

    <h2 class="sizing-section-heading">Unisex Tee — Size Chart</h2>
    <p class="sizing-note">All measurements in inches.</p>

    <div class="sizing-table-wrap">
      <table class="sizing-table">
        <thead>
          <tr>
            <th>Size</th>
            <th>Chest</th>
            <th>Length</th>
            <th>Sleeve</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>XS</strong></td>
            <td>32–34</td>
            <td>27</td>
            <td>8</td>
          </tr>
          <tr>
            <td><strong>S</strong></td>
            <td>34–36</td>
            <td>28</td>
            <td>8.5</td>
          </tr>
          <tr>
            <td><strong>M</strong></td>
            <td>38–40</td>
            <td>29</td>
            <td>9</td>
          </tr>
          <tr>
            <td><strong>L</strong></td>
            <td>42–44</td>
            <td>30</td>
            <td>9.5</td>
          </tr>
          <tr>
            <td><strong>XL</strong></td>
            <td>46–48</td>
            <td>31</td>
            <td>10</td>
          </tr>
          <tr>
            <td><strong>2XL</strong></td>
            <td>50–52</td>
            <td>32</td>
            <td>10.5</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="sizing-how-to">
      <h2 class="sizing-section-heading">How to Measure</h2>
      <div class="sizing-how-to__grid">
        <div class="sizing-how-to__item">
          <span class="sizing-how-to__number">01</span>
          <h3>Chest</h3>
          <p>Measure around the fullest part of your chest, keeping the tape horizontal under your armpits.</p>
        </div>
        <div class="sizing-how-to__item">
          <span class="sizing-how-to__number">02</span>
          <h3>Length</h3>
          <p>Measure from the top of the shoulder down to the bottom hem of the shirt.</p>
        </div>
        <div class="sizing-how-to__item">
          <span class="sizing-how-to__number">03</span>
          <h3>Sleeve</h3>
          <p>Measure from the shoulder seam to the end of the sleeve.</p>
        </div>
      </div>
    </div>

    <div class="sizing-tips">
      <h2 class="sizing-section-heading">Fit Tips</h2>
      <ul class="sizing-tips__list">
        <li>These are <strong>unisex relaxed-fit</strong> tees — they run slightly large.</li>
        <li>Want a fitted look? Size down one.</li>
        <li>Want that oversized streetwear feel? Stay true to size or go up one.</li>
        <li>100% cotton — expect about <strong>5% shrink</strong> after first wash. Wash cold, hang dry to keep the print sharp.</li>
      </ul>
    </div>

    <div class="sizing-cta fade-in">
      <p>Still not sure? <a href="/pages/contact">Contact us</a> and we will help you pick the right size.</p>
      <a href="/collections/all" class="btn btn--primary btn--large">Shop the Collection</a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Sizing Guide",
  "settings": [],
  "presets": [
    {
      "name": "Sizing Guide"
    }
  ]
}
{% endschema %}
