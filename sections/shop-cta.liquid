<section class="shop-cta">
  <div class="shop-cta__inner fade-in">
    <h2 class="shop-cta__heading">{{ section.settings.heading | default: 'Find Your Character.' }}</h2>
    <p class="shop-cta__subheading">{{ section.settings.subheading | default: "9 weirdos. 1 tee each. $29 and it's yours." }}</p>
    <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn btn--primary btn--xl">
      {{ section.settings.cta_text | default: 'Shop All Characters' }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Shop CTA",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find Your Character."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "9 weirdos. 1 tee each. $29 and it's yours."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Shop All Characters"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Shop CTA"
    }
  ]
}
{% endschema %}
